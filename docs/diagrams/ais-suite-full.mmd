flowchart LR
  aisFeed["AIS / GPS / Signal K vessel deltas"]
  signalK[("Signal K Server\nData API, resources, plugin routes")]

  subgraph Core["Core Safety Layer"]
    aisPlus["AIS Plus\nalert brain + chart app"]
    uiState["Server-authored UI projections\n/uiState, /compactAlertFeed,\n/panelEvents, /browserSpeechEvents"]
  end

  subgraph Data["Shared Data Helpers"]
    vesselDb["Vessel Database\nlearns static MMSI details"]
    harbourResources["Signal K regions resources\nHarbour:* limits"]
    harbourRepo[("signalk-harbours git repo")]
  end

  subgraph Clients["User Interfaces"]
    console["Watchkeeper Console\nsystem controls and status"]
    display["Watchkeeper Display\nchart, targets, profiles,\nsettings"]
    alerts["Watchkeeper Alerts\ncrew alert viewer"]
  end

  subgraph Audio["Audio Output"]
    audioPlugin["AIS Plus Audio\nPiper + directional ping renderer"]
    piSpeaker["Pi local speaker"]
    mp3Stream["LAN MP3 live stream\nradio player / phone"]
    generatedAudio["Rendered announcement files"]
  end

  subgraph Editing["Harbour Editing"]
    harbourEditor["Harbour Editor\nmap-first harbour editor"]
  end

  subgraph TestOps["Testing / Operations"]
    watchkeeperSim["Watchkeeper Simulator\nown-vessel, targets, GPS,\nweather, depth, tide"]
    capturePlus["CapturePlus\ncapture, replay, clips"]
    aiSnapshot["AI Snapshot\ncompact ChatGPT/debug JSON"]
    piController["Pi Controller\nstatus / control sidecar"]
  end

  aisFeed --> signalK
  watchkeeperSim --> signalK
  capturePlus <--> signalK
  capturePlus -->|"publishes plugins.capturePlus.playback"| aisPlus

  signalK -->|"AIS targets, own vessel,\nGPS, chart resources"| aisPlus
  aisPlus -->|"alerts, notifications,\nsilence/profile state,\nUI projections"| signalK
  aisPlus --> uiState

  signalK -->|"static AIS fields seen in deltas"| vesselDb
  vesselDb -->|"fills missing static data\nname, type, dimensions"| signalK
  signalK -->|"enriched vessel contexts"| aisPlus

  harbourEditor <-->|"create/edit/import/export\nHarbour:* regions"| signalK
  harbourEditor <--> harbourRepo
  signalK -->|"Harbour:* regions"| harbourResources
  harbourResources -->|"auto Harbour/Coastal profile\nand harbour-limit display"| aisPlus

  uiState --> display
  signalK -->|"chart resources + live vessel data"| display
  display -->|"profile/settings/silence actions"| aisPlus

  signalK -->|"Watchkeeper system state\nand plugin routes"| console
  console -->|"profile/settings/silence actions"| aisPlus

  signalK -->|"Notifications Plus projections\nand compact alert feed"| alerts
  alerts -->|"quick actions"| aisPlus

  signalK -->|"selected Signal K state\nand plugin routes"| aiSnapshot

  aisPlus -->|"announcement events\nAIS Plus decides what is worth saying"| audioPlugin
  audioPlugin -->|"status at vessels.self.plugins.aisPlusAudio"| signalK
  audioPlugin --> generatedAudio
  generatedAudio --> alerts
  audioPlugin --> piSpeaker
  audioPlugin --> mp3Stream
